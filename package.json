{
  "name": "simple-map",
  "version": "0.1.0",
  "description": "Simple Map front-end built with Vue and Pinia.",
  "type": "module",
  "packageManager": "bun@1.1.34",
  "scripts": {
    "dev": "bun ./node_modules/vite/bin/vite.js",
    "build": "bun ./node_modules/vue-tsc/bin/vue-tsc.js --noEmit && bun ./node_modules/vite/bin/vite.js build",
    "preview": "bun ./node_modules/vite/bin/vite.js preview",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "flag-icons": "^7.5.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rushstack/eslint-patch": "^1.16.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.11",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.1.10"
  },
  "private": true
}
